      "footer_y": [770.6, 781.6]
    }
  },

  "colors": {
    "primary_cyan":       { "hex": "#00AEEF", "use": "section headers, running headers, labels, rules" },
    "gradient_range":     { "from": "#00AEEF", "to": "#00BCF2", "use": "opener bars", "note": "12+ interpolated stops measured" },
    "pale_fill":          { "hex": "#C7EAFB", "use": "opener sidebar TOC box, Summary box" },
    "example_fill":       { "hex": "#D4EFFC", "use": "example box background", "note": "distinct from pale_fill - do not merge" },
    "example_body_text":  { "hex": "#00BDF2", "use": "text INSIDE example boxes" },
    "body_text":          { "hex": "#231F20", "use": "all black body copy (rich black, NOT #000000)" },
    "footer_text":        { "hex": "#000000", "use": "Reprint 2026-27 only" },
    "watermark":          { "hex": "#000000", "alpha": "low", "use": "diagonal 'not to be republished'" }
  },

  "typography": {
    "family": "Bookman",
    "weights_observed": ["Bookman-Light", "Bookman-Demi", "Bookman-DemiItalic", "Bookman,Bold", "Bookman,Italic"],
    "other_fonts": { "Symbol": "glyphs", "Arial": "footer only" },
    "roles": {
      "chapter_label":     { "text": "CHAPTER ONE", "font": "Bookman Bold", "size": 14, "color": "#231F20", "style": "small caps, centered" },
      "chapter_title":     { "font": "Bookman Bold", "size": 20, "color": "#231F20", "style": "small caps, centered" },
      "section_header": {
        "two_color": true,
        "warning": "the NUMBER is BLACK, not cyan. Filtering by color==#00AEEF matches the title only and drops the number.",
        "number": { "font": "Bookman,Bold", "size": 10, "color": "#231F20", "example": "1.1  " },
        "title":  { "font": "Bookman,Bold", "size": 10, "color": "#00AEEF", "case": "ALL CAPS", "example": "INTRODUCTION" }
      },
      "subsection_header": {
        "two_color": true,
        "warning": "same trap as section_header - number is BLACK",
