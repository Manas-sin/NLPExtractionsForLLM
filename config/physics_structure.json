{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "spec_name": "NCERT Physics Class XI Part I — Layout Structure",
  "spec_version": "1.0.0",
  "source_book": {
    "book_code": "11086",
    "title": "Physics (Part I)",
    "class": "XI",
    "publisher": "NCERT",
    "qr_code_format": "11086CH{NN}"
  },
  "provenance": "All values measured from source PDFs via PyMuPDF get_drawings/get_text and pdftotext. Not estimated.",

  "extraction_traps": {
    "read_first": true,
    "note": "Four measured defects in the source PDFs that silently corrupt naive extraction.",

    "trap_1_pua_font_corruption": {
      "severity": "critical",
      "description": "Some pages use a subsetted font whose ToUnicode CMap maps into the Unicode Private Use Area (U+F000-U+F0FF). pdftotext and PyMuPDF return unusable glyphs; text appears absent or garbled.",
      "detection": "count chars where 0xF000 <= ord(c) <= 0xF0FF",
      "fix_python": "''.join(chr(ord(c)-0xF000) if 0xF000<=ord(c)<=0xF0FF else c for c in s)",
      "measured_scope": {
        "keph107": { "pages_affected": 10, "total": 17, "severity": "majority" },
        "keph1ps": { "pages_affected": 13, "total": 16, "severity": "majority" },
        "keph102": { "pages_affected": 1, "total": 14 },
        "keph103": { "pages_affected": 1, "total": 22 },
        "keph101": { "pages_affected": 0, "total": 12 },
        "keph104": { "pages_affected": 0, "total": 22 },
        "keph105": { "pages_affected": 0, "total": 21 },
        "keph106": { "pages_affected": 0, "total": 35 },
        "keph1an": { "pages_affected": 0, "total": 9 },
        "keph1a1": { "pages_affected": 0, "total": 16 }
      },
      "consequence": "chapter 7 title and the entire front matter appear empty on first extraction"
    },

    "trap_2_geometry_not_uniform": {
      "severity": "high",
      "description": "MediaBox and CropBox differ ACROSS FILES. Absolute coordinates are not portable.",
      "per_file": {
        "keph101": { "mediabox": [657.35, 847.45], "cropbox_origin": [27, 27] },
        "keph102": { "mediabox": [657.00, 847.80], "cropbox_origin": [27, 27] },
        "keph103": { "mediabox": [657.00, 847.80], "cropbox_origin": [27, 27] },
        "keph104": { "mediabox": [657.00, 847.80], "cropbox_origin": [27, 27] },
        "keph105": { "mediabox": [657.00, 847.80], "cropbox_origin": [27, 27] },
        "keph106": { "mediabox": [657.35, 847.45], "cropbox_origin": [27, 27] },
        "keph107": { "mediabox": [657.35, 847.45], "cropbox_origin": [0, 0], "anomaly": true },
        "keph1ps": { "mediabox": [648.00, 864.00], "cropbox_origin": [20, 40], "anomaly": true },
        "keph1an": { "mediabox": [657.35, 847.45], "cropbox_origin": [27, 27] },
        "keph1a1": { "mediabox": [657.35, 847.45], "cropbox_origin": [27, 27] }
      },
      "measured_consequence": {
        "keph101": { "odd_x0": 46.7, "even_x0": 82.7 },
        "keph107": { "odd_x0": 73.7, "even_x0": 109.7, "note": "+27pt relative to keph101" }
      },
      "rule": "NEVER hard-code absolute x-coordinates across files. Derive column boundaries per-page by clustering block x0 values. The coordinates in page_geometry are reference values for keph101 only, not universal constants."
    },

    "trap_3_parity_not_pdf_index": {
      "severity": "high",
      "description": "Margins are mirrored, but parity follows the PRINTED BOOK page number, not the PDF page index. Chapter files are cut from the full book, so chapter 7 does not start on an odd book page.",
      "evidence": {
        "keph101_pdf_page_1": { "parity_by_x0": "odd", "parity_by_pdf_index": "odd", "match": true },
        "keph107_pdf_page_1": { "parity_by_x0": "even", "parity_by_pdf_index": "odd", "match": false }
      },
      "rule": "infer parity from measured x0, or from the printed page number in the running header. NEVER from page_index % 2."
    },

    "trap_4_vector_figures": {
      "severity": "high",
      "description": "Physics figures are overwhelmingly vector line art (free-body diagrams, vector triangles), not embedded bitmaps.",
      "consequence": "pdfimages -png returns almost nothing",
      "rule": "figure extraction requires page rendering + crop, or vector-bbox detection",
      "note": "matters far more in physics than chemistry"
    }
  },

  "differs_from_chemistry": {
    "note": "Physics is structurally different from the chemistry spec (NCERT_STRUCTURE.md). Do not reuse.",
    "chapter_label": "CHAPTER ONE (spelled out) vs Unit 1",
    "accent_color": "cyan #00AEEF vs pink/magenta",
    "opener_sidebar": "section TOC vs Objectives box",
    "body_grid": "true two-column vs sidebar + single column",
    "example_style": "filled cyan box + Answer outside vs margin labels + Solution",
    "intext_questions": "ZERO in physics vs 9-12 per chemistry unit",
    "answers_location": "separate file keph1an.pdf vs inline at end of unit",
    "solution_keyword": "Answer vs Solution",
    "margins": "mirrored (odd/even differ by 36pt)"
  },

  "files": {
    "naming_pattern": "keph1{part}",
    "decode": {
      "keph": "Class XI physics",
      "1": "Part I",
      "01-07": "chapter number",
      "ps": "prelims / front matter",
      "an": "answers",
      "a1": "appendices"
    },
    "inventory": [
      { "file": "keph1ps.pdf", "role": "prelims",    "pages": 16, "notes": "pages 1,4,6 are image-only (near-zero extractable text)" },
      { "file": "keph101.pdf", "role": "chapter", "chapter": 1, "pages": 12, "title": "Units and Measurement" },
      { "file": "keph102.pdf", "role": "chapter", "chapter": 2, "pages": 14, "title": "Motion in a Straight Line" },
      { "file": "keph103.pdf", "role": "chapter", "chapter": 3, "pages": 22, "title": "Motion in a Plane" },
      { "file": "keph104.pdf", "role": "chapter", "chapter": 4, "pages": 22, "title": "Laws of Motion" },
      { "file": "keph105.pdf", "role": "chapter", "chapter": 5, "pages": 21, "title": "Work, Energy and Power" },
      { "file": "keph106.pdf", "role": "chapter", "chapter": 6, "pages": 35, "title": "Systems of Particles and Rotational Motion" },
      { "file": "keph107.pdf", "role": "chapter", "chapter": 7, "pages": 17, "title": "Gravitation" },
      { "file": "keph1an.pdf", "role": "answers",    "pages": 9,  "notes": "grouped by 'Chapter N' heading; coverage is PARTIAL" },
      { "file": "keph1a1.pdf", "role": "appendices", "pages": 16, "notes": "Greek alphabet, SI prefixes, constants" }
    ]
  },

