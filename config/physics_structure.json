        "title":  { "font": ["Bookman,Bold", "Bookman-Demi"], "size": 10, "color": "#00AEEF", "case": "Title Case", "example": "Rounding off the Uncertain Digits" },
        "font_varies": "1.3.2 uses Bookman,Bold; 1.6.1 uses Bookman-Demi for the same role. Match on size+colour, NEVER font name."
      },
      "body_text":         { "font": "Bookman-Light", "size": 10, "color": "#231F20", "align": "justified" },
      "sidebar_toc":       { "font": "Bookman-Light", "size": 9, "color": "#00AEEF" },
