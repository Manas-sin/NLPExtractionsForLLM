      "example_body":      { "font": "Bookman-Light", "size": 10, "color": "#00BDF2", "location": "inside box" },
      "answer_label":      { "font": "Bookman-DemiItalic", "size": 10, "color": "#00AEEF", "location": "outside box" },
      "answer_body":       { "font": "Bookman-Light", "size": 10, "color": "#231F20", "location": "outside box" },
